# ── MediPredict Frontend Environment Variables ──
# Copy this file to .env.local for local development,
# and set these same values in your Vercel project dashboard.

# Backend API URL (no trailing slash)
# Local dev  → http://localhost:8000
# Production → https://medipredict-api.onrender.com  (replace with your actual Render URL)
VITE_API_URL=http://localhost:8000
